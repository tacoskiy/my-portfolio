---
import Book from '../components/Book.astro';
import { Image } from 'astro:assets';

// Original image imports (Astro optimizes these automatically)
import profileImg from '../assets/profile.jpg';
import case1Img from '../assets/case1.jpg';
import coverImg from '../assets/cover-new.jpg';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>My Portfolio Book</title>
    <!-- Load required fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Noto+Sans+JP:wght@400;700&family=Micro+5&display=swap" rel="stylesheet">
    <style is:global>
      body {
        margin: 0;
        padding: 0;
        overflow: hidden; /* No scrolling allowed */
        background: #121212; /* Behind the book context */
      }
      *, *::before, *::after {
        box-sizing: border-box;
      }

      /* Figma Link Cards Interactive Styles */
      .figma-card {
        display: block;
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border: 1px solid #eaeaea;
        text-decoration: none !important;
        color: inherit;
        transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
        cursor: pointer;
      }
      .figma-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        border-color: #d0d0d0;
      }
      .figma-card:active {
        transform: translateY(2px) scale(0.98);
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: all 0.1s ease;
      }
      .figma-card h3 {
        margin-top: 0;
        font-size: 1.1rem;
        color: #111;
      }
      .figma-card p {
        font-size: 0.9rem;
        margin-bottom: 1rem;
        color: #555;
      }
      .figma-card:hover .pdf-attachment {
        background: #111;
        color: #fff;
        border-color: #111;
      }
    </style>
  </head>
  <body>
    <!-- Accessibility main region -->
    <main aria-label="インタラクティブ・ポートフォリオブック" tabindex="-1">
      <Book>
          
          <!-- ========================================== -->
          <!-- FRONT COVER (CSS RECONSTRUCTION)           -->
          <!-- ========================================== -->
        <div slot="cover-front" style="
          height: 100%; 
          width: 100%; 
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          position: relative;
          color: white;
          overflow: hidden;
        ">
          <!-- Central Stripe with 3D SVG -->
