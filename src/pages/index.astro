      <stop offset="0.05" stop-color="#A9A0AC"/>
      <stop offset="0.1" stop-color="#FCF9FD"/> <!-- Extra bright pop -->
      <stop offset="0.2" stop-color="#C89E31"/>
      <stop offset="0.32" stop-color="#963A94"/>
      <stop offset="0.5" stop-color="#2B188E"/>
      <stop offset="0.68" stop-color="#963A94"/>
      <stop offset="0.8" stop-color="#C89E31"/>
      <stop offset="0.9" stop-color="#FCF9FD"/> <!-- Extra bright pop -->
      <stop offset="0.95" stop-color="#A9A0AC"/>
