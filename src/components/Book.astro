---
export interface Props {
  chapters?: { leaf: number; title: string }[];
}

// Determine how many page slots the user provided dynamically.
// We expect slots named "page-1", "page-2", "page-3"...
const slotNames = Object.keys(Astro.slots).filter((name) =>
  name.startsWith("page-"),
);
const totalUserPages = slotNames.length;

// Convert into strict "physical leaves" (Sheets of paper)
// Each leaf has a 'front' face and a 'back' face.
const leaves = [];

// Front Cover Leaf (Leaf 0)
// Front: The outside cover
// Back: The inside of the front cover (blank endpaper)
leaves.push({
  isCover: true,
  front: Astro.slots.has("cover-front")
    ? { type: "slot", name: "cover-front" }
    : { type: "cover", title: "Portfolio" },
  back: Astro.slots.has("cover-inside")
    ? { type: "slot", name: "cover-inside" }
    : { type: "blank" },
});

// Content Pages (1-indexed based on the slot names)
for (let i = 1; i <= totalUserPages; i += 2) {
  leaves.push({
    isCover: false,
    front: Astro.slots.has(`page-${i}`)
      ? { type: "slot", name: `page-${i}` }
      : { type: "blank" },
    back: Astro.slots.has(`page-${i + 1}`)
      ? { type: "slot", name: `page-${i + 1}` }
      : { type: "blank" },
  });
}

// Back Cover Leaf
// Front: The inside of the back cover (blank)
// Back: The outside of the back cover ("Fin")
leaves.push({
  isCover: true,
  front: { type: "blank" },
  back: Astro.slots.has("cover-back")
    ? { type: "slot", name: "cover-back" }
    : { type: "backCover", title: "Fin" },
});

const totalLeaves = leaves.length;
const { chapters = [] } = Astro.props as Props;
---

<div class="scene" id="main-scene">
  <div class="bg-loading-indicator" id="bg-loader">
    <span class="pulse-text">LOADING<span class="dots"></span></span>
  </div>

  <div
    id="book-object-tilt"
    style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; transform-style: preserve-3d; pointer-events: none; will-change: transform;"
  >
    <div class="book-entrance-wrapper">
      <div class="book" id="book" style="pointer-events: none;">
        <!-- Center spine visual binding -->
        <div class="binding"></div>

        {
          leaves.map((leaf, index) => {
            // Classic Z-Index Structure:
            // Initially, all leaves are on the right.
            // Leaf 0 needs the highest Z-index so it's on top.
            const rawZ = totalLeaves - index;
            return (
              <div
                class={`leaf ${leaf.isCover ? "is-hardcover" : ""}`}
                data-index={index}
                data-z-right={rawZ}
                data-z-left={index}
                style={`z-index: ${rawZ}; transform: rotateY(0deg) translateZ(${-index * 0.5}px);`}
              >
                {/* FRONT FACE (Visible when on the right side) */}
                <div class="face front">
                  {leaf.isCover && <div class="cover-texture-layer" />}
                  <div class="page-content">
                    {leaf.front.type === "cover" && (
                      <div class="cover-design">
                        <h1>{leaf.front.title}</h1>
                        <p class="hint">Click to open</p>
                      </div>
                    )}
                    {leaf.front.type === "slot" && (
                      <div
                        class={`page-slot-wrapper ${leaf.isCover ? "cover-html" : "standard-page"}`}
                      >
                        <Fragment
                          set:html={Astro.slots.render(leaf.front.name!)}
                        />
                      </div>
                    )}
                    {leaf.front.type === "blank" && <div class="blank-page" />}
                  </div>
                  <div class="shading" />
                </div>

                {/* BACK FACE (Visible when flipped to the left side) */}
                <div class="face back">
                  {leaf.isCover && <div class="cover-texture-layer" />}
                  <div class="page-content">
                    {leaf.back.type === "backCover" && (
                      <div class="cover-design back-cover-design">
                        <h1>{leaf.back.title}</h1>
                        <p class="hint">The End</p>
                      </div>
                    )}
                    {leaf.back.type === "slot" && (
                      <div
                        class={`page-slot-wrapper ${leaf.isCover ? "cover-html" : "standard-page"}`}
                      >
                        <Fragment
                          set:html={Astro.slots.render(leaf.back.name!)}
                        />
                      </div>
                    )}
                    {leaf.back.type === "blank" && <div class="blank-page" />}
                  </div>
                  <div class="shading" />
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>

  <div class="controls" id="controls">
    <button id="btn-prev" aria-label="Previous Page" class="nav-btn">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M15 18l-6-6 6-6"></path></svg
      >
    </button>
    <button id="btn-next" aria-label="Next Page" class="nav-btn">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </button>
  </div>

  {
    chapters.length > 0 && (
      <div class="chapter-nav">
        {chapters.map((chap) => (
          <button class="chapter-btn" data-target-leaf={chap.leaf}>
            {chap.title}
          </button>
        ))}
      </div>
    )
  }

  <div id="chapter-fade"></div>
</div>

<style>
  /* 
  CLASSIC CSS 3D BOOK STRUCTURE
  - No dynamic `translateZ` physics or parallax offsets.
  - The book is absolutely stationary. 
  - The spine is permanently anchored to the exact center.
  - Leaves pivot -180deg exactly around the spine.
*/
  :root {
    --leaf-duration: 0.9s;
    --bg-dark: #0a0a0b;
    --bg-accent: #1a1a1a;
    --cover-bg: #1e1e1e;
    --page-bg: #e3ddce;
    --text-main: #111111;
    --text-muted: #555555;
    --cover-text: #ffffff;

    /* ====== 本のカバーのテクスチャ透明度 ====== */
    /* ここでテクスチャの濃さを自由に調整できます。
     0.05（うっすら）〜 0.15（はっきり）程度がおすすめです。 */
    --book-texture-opacity: 0.025;

    --page-bg: #fdfaf5; /* Warm eggshell white */
    --text-main: #111111;
    --text-muted: #555555;
  }

  .chapter-nav {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1rem;
    z-index: 1000;
    pointer-events: auto;
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  .scene.nav-hidden .chapter-nav {
    opacity: 0;
    pointer-events: none;
  }
  .chapter-btn {
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.95);
    padding: 0.6rem 1.25rem;
    font-family: "Inter", "Noto Sans JP", sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .chapter-btn:hover {
    background: rgba(0, 0, 0, 0.8);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .chapter-btn.is-active {
    background: #ffffff;
    color: #111111;
    border-color: #ffffff;
  }

  /* Chapter transition fade overlay */
  #chapter-fade {
    position: fixed;
    inset: 0;
    background: #0a0a0b;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 99999;
  }
  #chapter-fade.fade-in {
    opacity: 1;
    pointer-events: all;
  }

  .scene {
    background: var(--bg-dark);
    position: relative;
    width: 100vw;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 2500px;
    overflow: hidden;
    font-family: "Noto Sans JP", "Inter", sans-serif;
  }

  /* Atmospheric Mesh Gradient - Optimized with reduced blur and simpler layers */
  .scene::before {
    content: "";
    position: absolute;
    inset: -20%; /* Reduced from -50% to save fill rate */
    background:
      radial-gradient(circle at 20% 30%, var(--bg-accent) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, #1a1a1a 0%, transparent 50%);
    filter: blur(40px); /* Reduced from 80px */
    opacity: 0.5;
    will-change: transform;
    animation: mesh-drift 30s infinite alternate linear; /* Slower and simpler curve */
    z-index: -1;
  }

  /* 3D Floor Shadow/Reflection - Simplified */
  .scene::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 30%;
    bottom: 0;
    left: 0;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 0.5) 0%,
      transparent 80%
    );
    transform: rotateX(80deg);
    filter: blur(15px);
    z-index: -1;
    opacity: 0;
    will-change: opacity, transform;
  }

  /* Animations apply ONLY after loading finishes */
  .scene.is-loaded::after {
    animation: shadow-entrance-sequence 2s cubic-bezier(0.1, 0.8, 0.2, 1)
      forwards;
  }

  @keyframes shadow-entrance-sequence {
    0% {
      opacity: 0;
      transform: rotateX(80deg) scale(0.3) translateY(-100px);
      filter: blur(40px);
      background: radial-gradient(
        ellipse at center,
        rgba(10, 5, 0, 0.9) 0%,
        transparent 60%
      );
    }
    100% {
      opacity: 1;
      transform: rotateX(80deg) scale(1) translateY(0);
      filter: blur(25px);
      background: radial-gradient(
        ellipse at center,
        rgba(30, 15, 0, 0.6) 0%,
        transparent 70%
      );
    }
  }

  @keyframes mesh-drift {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(5%, 5%) scale(1.1);
    }
  }

  .book-entrance-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    /* Start hidden & offscreen */
    transform: translateY(120vh) translateZ(100px) rotateX(20deg) scale(1.05);
  }

  .scene.is-loaded .book-entrance-wrapper {
    animation: book-entrance-sequence 2s cubic-bezier(0.1, 0.8, 0.2, 1) forwards;
  }

  @keyframes book-entrance-sequence {
    0% {
      /* Starts deep off-screen gently */
      transform: translateY(120vh) translateZ(100px) rotateX(20deg) scale(1.05);
    }
    100% {
      /* Final suspended floating state */
      transform: translateY(0) translateZ(0) rotateX(0deg) scale(1);
    }
  }

  .bg-loading-indicator {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--cover-text);
    font-family: "Inter", sans-serif;
    font-size: 1.5rem; /* Increased size */
    font-weight: 600; /* Bolder */
    letter-spacing: 0.4em;
    z-index: -2; /* Completely behind the 3D book shadow floor */
    opacity: 0.9; /* Increased baseline opacity */
  }

  .bg-loading-indicator .pulse-text {
    animation: load-pulse 1.5s infinite alternate ease-in-out;
    display: inline-block;
  }

  @keyframes load-pulse {
    0% {
      opacity: 0.5;
      filter: blur(1px);
    }
    100% {
      opacity: 1;
      filter: blur(0px);
    }
  }

  .bg-loading-indicator .dots::after {
    content: "";
    animation: loading-dots 1.5s steps(4, end) infinite;
  }

  @keyframes loading-dots {
    0% {
      content: "";
    }
    25% {
      content: ".";
    }
    50% {
      content: "..";
    }
    75% {
      content: "...";
    }
    100% {
      content: "";
    }
  }

  /* Gracefully fade out the loader once the book is fully in position */
  .scene.is-loaded .bg-loading-indicator {
    animation: fade-out 1s linear 2s forwards;
  }

  @keyframes fade-out {
    0% {
      opacity: 0.9;
    }
    100% {
      opacity: 0;
      pointer-events: none;
    }
  }

  .book {
    position: relative;
    /* Width defines the FULL two-page spread */
    width: calc(100vw - 72px);
    max-width: none;
    height: calc(100vh - 72px);
    max-height: none;
    transform-style: preserve-3d;
    /* Start centered on the front cover by offsetting the full spread half-width */
    transform: translateX(-25%);
    transition: transform var(--leaf-duration) cubic-bezier(0.5, 0, 0.2, 1);
    will-change: transform;
  }

  /* The 3D rounded binding (Spine) */
  .binding {
    position: absolute;
    top: -8.5px;
    left: 50%;
    bottom: -8.5px;
    width: 22px; /* Refined width */
    transform: translateX(-50%) translateZ(-8px) rotateY(0deg);
    background: var(--cover-bg);
    background-image: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(0, 0, 0, 0.6) 100%
    );
    z-index: -10;
    box-shadow: 0 5px 25px rgba(0, 0, 0, 0.4);
    border-radius: 11px; /* Half of width */
    transform-style: preserve-3d;
    transition:
      opacity 0.4s ease,
      visibility 0.4s ease;
  }

  /* Hide spine when book is open */
  .book[data-open-status="open"] .binding {
    opacity: 0;
    visibility: hidden;
  }

  /* Spine Side Faces for Volume */
  .binding::before,
  .binding::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 8px;
    background: #000;
  }
  .binding::before {
    left: 0;
    transform: rotateY(-90deg) translateX(-4px);
    transform-origin: left;
  }
  .binding::after {
    right: 0;
    transform: rotateY(90deg) translateX(4px);
    transform-origin: right;
    /* Removal of semi-transparency */
  }

  /* 
  Leaves are exactly 50% width, placed on the RIGHT side.
  Transform origin is the LEFT edge (which sits perfectly at 50% screen center).
*/
  .leaf {
    position: absolute;
    right: 0;
    top: 0;
    width: 50%;
    height: 100%;
    transform-origin: left center;
    transform-style: preserve-3d;
    transition: transform var(--leaf-duration) cubic-bezier(0.5, 0, 0.2, 1);
    /* z-index is handled by style injections initially, and JS during interactions */
  }

  /* Hardware accelerate the flipping */
  .leaf.is-flipping {
    will-change: transform;
  }

  .face {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden; /* Hides rear geometry when rotated */
    background-color: var(--page-bg);
    box-sizing: border-box;
    overflow: clip; /* Use 'clip' instead of 'hidden' — does NOT create a new stacking context in 3D, so children remain hittable */
    pointer-events: auto; /* Re-enable events on the actual page surfaces (book container is none) */
    /* Paper Grain + Subtle Depth Gradient */
    background-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.02),
      transparent 10%,
      transparent 90%,
      rgba(0, 0, 0, 0.02)
    );
    background-blend-mode: multiply;
    opacity: 0.99;
    box-shadow: inset 0 0 25px rgba(0, 0, 0, 0.05);
    transform-style: preserve-3d;
  }

  /* Page Stack Visual Edge (Multi-shadow for thickness) */
  .face.front {
    transform: rotateY(0deg);
    border-radius: 0 4px 4px 0;
    border-left: 1px solid rgba(0, 0, 0, 0.04);
    /* Simulated thickness via simpler shadows */
    box-shadow:
      inset 0 0 20px rgba(0, 0, 0, 0.05),
      2px 0 4px rgba(0, 0, 0, 0.1);
  }

  .face.back {
    transform: rotateY(180deg);
    background-color: var(--page-bg);
    border-radius: 4px 0 0 4px;
    border-right: 1px solid rgba(0, 0, 0, 0.04);
    /* Simulated thickness via shadows */
    box-shadow:
      inset 0 0 25px rgba(0, 0, 0, 0.05),
      -1px 0 0 #e5e0d8,
      -2px 0 0 #d9d4cc,
      -3px 0 5px rgba(0, 0, 0, 0.1);
  }

  /* Spine Crease Visual (Ambient Occlusion at the fold) */
  .face.front::before,
  .face.back::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30px;
    z-index: 5;
    pointer-events: none;
  }
  .face.front::before {
    left: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.1), transparent);
  }
  .face.back::before {
    right: 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.1), transparent);
  }

  /* Hardcover Specifics */
  /* Overhang: Make the hardcover slightly larger than the inner pages */
  .leaf.is-hardcover {
    /* Give covers a thicker feel via drop shadow */
    box-shadow: 5px 10px 20px rgba(0, 0, 0, 0.15);
    /* The leaf container dictates the hinge. We enlarge the faces rather than the leaf itself 
     so the hinge (left: 0) remains perfectly aligned with the spine. */
  }

  .leaf.is-hardcover .face {
    /* Expand top, bottom, and right edge (but keep left edge anchored at the spine) */
    top: -8px;
    bottom: -8px;
    height: calc(100% + 16px);
    width: calc(100% + 10px);
    transform-style: preserve-3d;
  }

  .leaf.is-hardcover .face.front {
    background-color: var(--cover-bg);
    border-radius: 2px 8px 8px 2px;
    border: 1px solid rgba(255, 255, 255, 0.08); /* Slightly more visible border */
    transform: rotateY(0deg);
    /* Thicker cover shadow */
    box-shadow:
      inset 0 0 40px rgba(0, 0, 0, 0.2),
      1px 0 0 #111,
      2px 0 0 #000,
      4px 0 10px rgba(0, 0, 0, 0.3);
  }
  .leaf.is-hardcover .face.back {
    background-color: var(--cover-bg); /* inside lining */
    border-radius: 8px 2px 2px 8px;
    transform: rotateY(180deg);
    box-shadow:
      inset 0 0 40px rgba(0, 0, 0, 0.2),
      -1px 0 0 #111,
      -2px 0 0 #000,
      -4px 0 10px rgba(0, 0, 0, 0.3);
  }

  /* Texture Layer injected via Astro for covers */
  .cover-texture-layer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    background-image: url("/textures/book-tex.svg");
    background-size: 100%;
    background-blend-mode: normal;
    opacity: var(--book-texture-opacity);
  }

  .face.front .cover-texture-layer {
    border-radius: 2px 8px 8px 2px;
  }
  .face.back .cover-texture-layer {
    border-radius: 8px 2px 2px 8px;
  }

  .face.front::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.1), transparent);
    pointer-events: none;
  }

  .face.back::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 40px;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.1), transparent);
    pointer-events: none;
  }

  /* Realistic Shadow Gradients for flight */
  .shading {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    background: rgba(0, 0, 0, 0.12);
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: opacity;
  }

  /* When the page is actively flipping, mid-air shadows appear deeply */
  .leaf.is-flipping .shading {
    opacity: 1;
  }

  /* Content Layouts */
  .page-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 6vw;
    box-sizing: border-box;
    overflow-y: auto;
    overflow-x: hidden;
    pointer-events: auto;
    z-index: 5;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .page-content::-webkit-scrollbar {
    display: none;
  }

  /* Hardcovers: no internal scrolling */
  .leaf.is-hardcover .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Hardcovers: no mask */
  .leaf.is-hardcover .page-content {
    -webkit-mask-image: none;
    mask-image: none;
  }

  .cover-design {
    text-align: center;
    color: var(--cover-text);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  .cover-design h1 {
    font-size: 2.8rem;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    text-transform: uppercase;
    text-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }
  .hint {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.6;
    animation: pulse 3s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }

  /* Cover pages need full height to fill the face */
  .cover-html {
    height: 100%;
    width: 100%;
  }

  /* Standard pages: block flow so overflow is based on content, not flex sizing */
  .standard-page {
    width: 100%;
  }

  .cover-html :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .standard-page :global(h2) {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    color: var(--text-main);
    letter-spacing: 0.05em;
  }

  /* Global paragraph style for standard pages - Modern & Muted */
  :global(.standard-page p) {
    font-size: 1rem !important;
    line-height: 1.8 !important;
    color: #444 !important;
    max-width: 60ch;
    text-align: justify;
    font-weight: 300 !important;
    letter-spacing: 0.05em !important;
    font-family: "Noto Sans JP", sans-serif !important;
  }

  .standard-page :global(.page-image),
  .standard-page :global(img) {
    max-width: 100%;
    max-height: 50vh;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    margin-top: 1.5rem;
  }

  /* User Extensible Components */
  .standard-page :global(.status-tag) {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    background: #ffe3e3;
    color: #d12020;
    font-size: 0.8rem;
    font-weight: bold;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .standard-page :global(.status-tag.done) {
    background: #e3ffe3;
    color: #20d120;
  }

  .standard-page :global(.status-tag.in-progress) {
    background: #e3f0ff;
    color: #206bd1;
  }

  .standard-page :global(a.link-tag) {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 20px;
    background: #f4f6f8;
    color: #333;
    font-size: 0.85rem;
    font-weight: bold;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: 1px solid #e1e4e8;
    margin: 0 4px 1rem 0;
    transition: all 0.2s ease;
  }

  .standard-page :global(a.link-tag:hover) {
    background: #111;
    color: #fff;
    border-color: #111;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
  }

  .standard-page :global(a.link-tag:active) {
    transform: translateY(1px) scale(0.98);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  .standard-page :global(.pdf-attachment) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: #f4f6f8;
    border: 1px solid #e1e4e8;
    border-radius: 6px;
    color: #333;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s cubic-bezier(0.25, 1, 0.5, 1);
    margin-top: 1.5rem;
  }

  .standard-page :global(.pdf-attachment:hover) {
    background: #111;
    color: #fff;
    border-color: #111;
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
  }

  .standard-page :global(.pdf-attachment:active) {
    transform: translateY(1px) scale(0.98);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  .standard-page :global(.pdf-attachment svg) {
    width: 18px;
    height: 18px;
  }

  /* Nav Controls */
  .controls {
    position: fixed;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
    padding: 0 40px;
    z-index: 20000;
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  .scene.nav-hidden .controls {
    opacity: 0;
    pointer-events: none;
  }

  .nav-btn {
    pointer-events: auto;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.2s,
      background 0.2s,
      box-shadow 0.2s,
      border 0.2s,
      color 0.3s;
    /* Remove negative margin so buttons stay inside padding area */
    margin: 0;
  }

  .nav-btn:hover:not(:disabled) {
    transform: scale(1.1);
    background: rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
    color: white;
  }

  .nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transform: scale(1);
    box-shadow: none;
  }
</style>

<script>
  // --- [Loading Sequence Orchestration] ---
  // We wait until exactly everything (fonts, high-res images) finishes loading.
  window.addEventListener("load", () => {
    const scene = document.getElementById("main-scene");

    // Optional: Add a guaranteed 600ms minimum wait to ensure the elegant loader is appreciated even on fast connections
    const timeSinceNavStart = performance.now();
    const minWaitTime = 600;
    const waitLeft = Math.max(0, minWaitTime - timeSinceNavStart);

    setTimeout(() => {
      scene?.classList.add("is-loaded");
    }, waitLeft);
  });

  document.addEventListener("DOMContentLoaded", () => {
    const leaves = Array.from(
      document.querySelectorAll(".leaf"),
    ) as HTMLElement[];
    const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
    const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
    const controls = document.getElementById("controls") as HTMLElement;
    const book = document.getElementById("book") as HTMLElement;

    if (!leaves.length) return;

    const totalLeaves = leaves.length;
    let currentLeaf = 0; // Represents the left-most leaf on the right stack
    let isAnimating = false;
    let animTimeout: number | undefined;

    // --- Mouse Idle: hide nav after 2.5s of no movement ---
    const scene = document.getElementById("main-scene")!;
    let idleTimer: number | undefined;

    function showNav() {
      scene.classList.remove("nav-hidden");
      clearTimeout(idleTimer);
      idleTimer = window.setTimeout(() => {
        scene.classList.add("nav-hidden");
      }, 1000);
    }

    document.addEventListener("mousemove", showNav, { passive: true });
    // Also show on click/keypress so keyboard nav reveals buttons
    document.addEventListener("keydown", showNav, { passive: true });
    showNav(); // start the initial timer

    function updateBookPosition() {
      if (currentLeaf === 0) {
        book.style.transform = "translateX(-25%)";
        book.dataset.openStatus = "closed-front";
      } else if (currentLeaf === totalLeaves) {
        book.style.transform = "translateX(25%)";
        book.dataset.openStatus = "closed-back";
      } else {
        book.style.transform = "translateX(0%)";
        book.dataset.openStatus = "open";
      }
    }

    function updateLeafStates() {
      leaves.forEach((leaf, i) => {
        const distance =
          i < currentLeaf ? currentLeaf - 1 - i : i - currentLeaf;
        // Keep current spread + 1 page buffer for smooth stack visuals and transitions
        const isVisible = distance <= 2;
        leaf.style.visibility = isVisible ? "visible" : "hidden";

        // Only top pages of the left and right stack respond to clicks
        const isTop = i === currentLeaf - 1 || i === currentLeaf;
        leaf.style.pointerEvents = isTop ? "auto" : "none";
      });
    }

    function updateButtons() {
      btnPrev.disabled = currentLeaf === 0;
      btnNext.disabled = currentLeaf === totalLeaves;

      // Update chapter buttons
      document.querySelectorAll(".chapter-btn").forEach((btn) => {
        const target = parseInt(btn.getAttribute("data-target-leaf")!);
        if (target === currentLeaf) {
          btn.classList.add("is-active");
        } else {
          btn.classList.remove("is-active");
        }
      });
    }

    function turnNext() {
      if (currentLeaf >= totalLeaves || isAnimating) return;
      isAnimating = true;

      const leaf = leaves[currentLeaf];

      // To prevent clipping during rapid 3D flips, we use an ascending z-index based on flip order
      leaf.style.zIndex = (10000 - currentLeaf).toString();
      leaf.classList.add("is-flipping");

      // Maintain stack offset during flip to avoid intersection with neighboring pages
      const index = parseInt(leaf.getAttribute("data-index")!);
      leaf.style.transform = `rotateY(-180deg) translateZ(${-index * 0.5}px)`;

      currentLeaf++;

      // Animate the entire book block horizontally at the exact same moment
      // using the exact same cubic-bezier curve so it stays perfectly centered.
      updateBookPosition();
      updateButtons();

      clearTimeout(animTimeout);
      animTimeout = setTimeout(() => {
        // Upon completion, set the z-index to its mathematically correct left-stack depth.
        leaf.classList.remove("is-flipping");
        updateLeafStates();
        isAnimating = false;
      }, 900); // Wait for transition entirely
    }

    function turnPrev() {
      if (currentLeaf <= 0 || isAnimating) return;
      isAnimating = true;

      currentLeaf--;
      const leaf = leaves[currentLeaf];
      leaf.style.visibility = "visible"; // Ensure visible before animation

      leaf.style.zIndex = (10000 + currentLeaf).toString();
      leaf.classList.add("is-flipping");
      leaf.style.transform = `rotateY(0deg) translateZ(${-currentLeaf * 0.5}px)`;

      updateBookPosition();
      updateButtons();

      clearTimeout(animTimeout);
      animTimeout = setTimeout(() => {
        // Re-assign natural right-stack depth
        leaf.classList.remove("is-flipping");
        updateLeafStates();
        isAnimating = false;
      }, 900);
    }

    // Animated chapter jumping: fade out, snap all pages, fade back in
    function jumpToLeaf(target: number) {
      if (target === currentLeaf || isAnimating) return;
      isAnimating = true;

      const fadeEl = document.getElementById("chapter-fade")!;
      const isForward = target > currentLeaf;

      // Step 1: Fade to black
      fadeEl.classList.add("fade-in");

      setTimeout(() => {
        // Step 2: Instantly snap all pages while hidden
        book.style.transition = "none";
        leaves.forEach((l) => (l.style.transition = "none"));

        if (isForward) {
          for (let i = currentLeaf; i < target; i++) {
            const leaf = leaves[i];
            leaf.style.zIndex = leaf.getAttribute("data-z-left")!;
            const index = parseInt(leaf.getAttribute("data-index")!);
            leaf.style.transform = `rotateY(-180deg) translateZ(${-index * 0.5}px)`;
            leaf.classList.remove("is-flipping");
          }
        } else {
          for (let i = currentLeaf - 1; i >= target; i--) {
            const leaf = leaves[i];
            leaf.style.zIndex = leaf.getAttribute("data-z-right")!;
            leaf.style.transform = `rotateY(0deg) translateZ(${-i * 0.5}px)`;
            leaf.classList.remove("is-flipping");
          }
        }

        currentLeaf = target;
        updateBookPosition();
        updateButtons();
        updateLeafStates();

        // Force reflow
        book.offsetHeight;

        // Restore transitions
        book.style.transition = "";
        leaves.forEach((l) => (l.style.transition = ""));

        // Step 3: Fade back in
        fadeEl.classList.remove("fade-in");

        clearTimeout(animTimeout);
        animTimeout = setTimeout(() => {
          isAnimating = false;
        }, 300);
      }, 300); // Wait for fade-out to finish
    }

    document.querySelectorAll(".chapter-btn, .page-link").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const target = parseInt(btn.getAttribute("data-target-leaf")!);
        jumpToLeaf(target);
      });
    });

    // Click listeners for physical buttons
    btnNext?.addEventListener("click", turnNext);
    btnPrev?.addEventListener("click", turnPrev);

    // Book surface click handler — turns pages UNLESS clicking an interactive element
    book.addEventListener("click", (e) => {
      // If user clicked an interactive element (link, button, etc.), let the browser handle it natively
      const target = e.target as HTMLElement | null;
      if (
        target &&
        target.closest(
          'a, button, [role="button"], input, textarea, select, img, .pdf-click-area, iframe',
        )
      ) {
        return; // Do nothing — browser follows the link / activates the button / viewer opens
      }

      // Ignore text selection drags
      if (window.getSelection()?.toString().length) return;

      // Determine left vs right half → turn page
      const rect = book.getBoundingClientRect();
      const isRightSide = e.clientX > rect.left + rect.width / 2;
      if (isRightSide) turnNext();
      else turnPrev();
    });

    // Keyboard navigation
    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") turnNext();
      if (e.key === "ArrowLeft") turnPrev();
    });

    // Vertical Scroll (Wheel) navigation
    // --- Wheel Navigation with Grace Period ---
    let wheelTimeout: number | null = null;
    let edgeReachedTime = 0;
    let edgeTarget = ""; // "top" or "bottom"

    // Optimized delta normalization
    function normalizeDelta(raw: number, mode: number): number {
      if (mode === 1) return raw * 18;
      if (mode === 2) return raw * 350;
      return raw;
    }

    document.addEventListener(
      "wheel",
      (e) => {
        const deltaX = normalizeDelta(e.deltaX, e.deltaMode);
        const deltaY = normalizeDelta(e.deltaY, e.deltaMode);

        // --- Horizontal scroll: page turn (Immediate but with timeout) ---
        if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > 40) {
          e.preventDefault();
          if (wheelTimeout === null) {
            if (deltaX > 0) turnNext();
            else turnPrev();
            wheelTimeout = window.setTimeout(() => {
              wheelTimeout = null;
            }, 1000);
          }
          return;
        }

        // --- Vertical scroll ---
        if (Math.abs(deltaY) < 3) return;

        const pageContent = (e.target as HTMLElement | null)?.closest(
          ".page-content",
        ) as HTMLElement | null;

        if (pageContent) {
          const style = window.getComputedStyle(pageContent);
          const isLocked = style.overflowY === "hidden";
          const isScrollable =
            !isLocked &&
            pageContent.scrollHeight > pageContent.clientHeight + 2;

          if (isScrollable) {
            const atBottom =
              pageContent.scrollTop + pageContent.clientHeight >=
              pageContent.scrollHeight - 2;
            const atTop = pageContent.scrollTop <= 2;

            // 1. If we can still scroll within the page
            if ((deltaY > 0 && !atBottom) || (deltaY < 0 && !atTop)) {
              e.preventDefault();
              pageContent.scrollBy({ top: deltaY, behavior: "auto" });
              // Reset edge state because we are moving
              edgeTarget = "";
              return;
            }

            // 2. We are at a boundary (atTop or atBottom)
            if ((deltaY > 0 && atBottom) || (deltaY < 0 && atTop)) {
              e.preventDefault();
              const currentEdge = deltaY > 0 ? "bottom" : "top";

              // Start grace period timer if this is a new edge hit
              if (edgeTarget !== currentEdge) {
                edgeTarget = currentEdge;
                edgeReachedTime = Date.now();
                return;
              }

              // Check if 500ms has passed since hitting this edge
              const elapsed = Date.now() - edgeReachedTime;
              if (elapsed < 500) {
                return; // Still in grace period
              }
              // If elapsed > 500ms, fall through to page turn logic
            }
          } else {
            // Not a scrollable page - we still want a small nudge protection
            // so starting to scroll doesn't instantly flip.
            e.preventDefault();
            const currentEdge = deltaY > 0 ? "bottom" : "top";
            if (edgeTarget !== currentEdge) {
              edgeTarget = currentEdge;
              edgeReachedTime = Date.now();
              return;
            }
            if (Date.now() - edgeReachedTime < 400) return;
          }
        }

        // --- Page Turn ---
        if (Math.abs(deltaY) < 40) return;
        if (wheelTimeout === null) {
          if (deltaY > 0) turnNext();
          else turnPrev();
          wheelTimeout = window.setTimeout(() => {
            wheelTimeout = null;
          }, 1100);
          // After a flip, reset edge stats
          edgeTarget = "";
        }
      },
      { passive: false },
    );

    updateButtons();
    updateLeafStates();
  });
</script>
